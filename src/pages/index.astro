---
import Header from "../components/header.astro";
import Hero from "../section/hero.astro";
import Menu from "../section/menu.astro";
import Franchise from "../section/franchise.astro";
import Gallery from "../section/gallery.astro";
import Footer from "../section/footer.astro";
import FooterBar from "../components/footer.astro";

import Layout from "../layouts/Layout.astro";
---

<Layout>
  <Header />
  <Hero />
  <Menu />
  <Franchise />
  <Gallery />
  <Footer />
  <FooterBar />
</Layout>

<style lang="scss" is:global>
  @use "../assets/scss/mixin" as *;
  @use "../assets/scss/variables" as *;
  @use "../assets/scss/root" as *;
  @use "../assets/scss/base" as *;

  header,
  section:not(.hero-section) {
    padding: 6rem 10rem;
  }

  section:not(.hero-section) {
    height: 100vh;
    overflow: hidden;

    &.bg-section {
      background: var(--secBgClr);
    }
    &.ylw-section {
      background: var(--secPrimaryClr);
    }
  }
</style>
